# ---- Server ----
NODE_ENV=development
PORT=8080
# Comma-separated allowed origins for CORS (web + app)
CORS_ORIGINS=http://localhost:3000

# ---- Database (Prisma / Postgres) ----
DATABASE_URL=postgresql://movieverse:movieverse@localhost:5432/movieverse?schema=public

# ---- Auth ----
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change-me-too

# ---- TMDB ----
TMDB_API_KEY=
TMDB_BEARER_TOKEN=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# ---- AI service (MovieverseAI Flask) ----
AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_TOKEN=change-me-shared-with-node

# ---- Mail (OTP reset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@movieverse.local
