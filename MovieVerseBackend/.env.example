# If DATABASE_URL is set, backend will use it (recommended for Neon).
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/movieverse?sslmode=require
DATABASE_URL=

# Local docker postgres defaults (used when DATABASE_URL is empty)
POSTGRES_DB=movieverse
POSTGRES_USER=movieverse
POSTGRES_PASSWORD=movieverse

# Django settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

