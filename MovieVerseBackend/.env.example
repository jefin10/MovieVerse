# Docker Compose postgres (db service). Backend connects via DATABASE_URL set in docker-compose.yml.
POSTGRES_DB=movieverse
POSTGRES_USER=movieverse
POSTGRES_PASSWORD=movieverse

# Django settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=movieversebackend.jefin.xyz,localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://movieverse.jefin.xyz
CSRF_TRUSTED_ORIGINS=https://movieverse.jefin.xyz

# TMDB credentials for full catalog sync
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

# Optional if email features are used
EMAIL_HOST_PASSWORD=
